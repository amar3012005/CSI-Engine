<template>
  <div class="report-workspace-panel">
    <div v-if="loading" class="report-state loading">
      <div class="spinner"></div>
      <div class="state-copy">
        <h3>Generating report</h3>
        <p>The IEEE-style report is being drafted from the simulation output.</p>
      </div>
    </div>

    <div v-else-if="error" class="report-state error">
      <div class="state-copy">
        <h3>Report unavailable</h3>
        <p>{{ error }}</p>
      </div>
    </div>

    <div v-else-if="reportData" class="report-document">
      <div class="report-header">
        <div class="report-meta-row">
          <span class="report-tag">IEEE Manuscript</span>
          <span class="report-meta">{{ currentReportId }}</span>
          <span class="report-meta" v-if="reportData.created_at">Generated {{ formatDate(reportData.created_at) }}</span>
          <button class="view-paper-btn" @click="showPaper = true">
            View Paper
          </button>
        </div>
        <p v-if="paperSummary" class="report-summary">{{ paperSummary }}</p>
      </div>

      <div class="report-markdown markdown-body" v-html="renderedMarkdown"></div>
    </div>

    <div v-else class="report-state empty">
      <div class="state-copy">
        <h3>Report not started</h3>
        <p>Generate the final paper from the Simulation section to unlock the report here.</p>
      </div>
    </div>

    <!-- Full page POV modal -->
    <FullPaperModal
      v-model="showPaper"
      :report-id="currentReportId"
      :report-data="reportData"
      :loading="loading"
    />
  </div>
</template>

<script setup>
import { computed, onBeforeUnmount, ref, watch } from 'vue'
import DOMPurify from 'dompurify'
import { marked } from 'marked'
import { getPaperReportBySimulation, getReport } from '../api/report'
import FullPaperModal from './FullPaperModal.vue'

const props = defineProps({
  simulationId: {
    type: String,
    default: ''
  },
  reportId: {
    type: String,
    default: ''
  },
  reportStarted: {
    type: Boolean,
    default: false
  }
})

const emit = defineEmits(['report-loaded'])

const reportData = ref(null)
const loading = ref(false)
const showPaper = ref(false)
const error = ref('')
const currentReportId = ref(props.reportId || '')
let pollTimer = null

const paperSummary = computed(() => {
  return reportData.value?.outline?.summary || ''
})

const reportMarkdown = computed(() => {
  if (!reportData.value) return ''
  if (reportData.value.markdown_content) return reportData.value.markdown_content
  if (reportData.value.content) return reportData.value.content
  if (reportData.value.sections?.length) {
    return reportData.value.sections.map((section) => section.content || '').join('\n\n')
  }
  if (reportData.value.outline?.sections?.length) {
    return reportData.value.outline.sections
      .map((section) => `## ${section.title}\n\n${section.content || ''}`.trim())
      .join('\n\n')
  }
  return ''
})

const renderedMarkdown = computed(() => {
  if (!reportMarkdown.value) return ''
  return DOMPurify.sanitize(marked.parse(reportMarkdown.value))
})

const startPolling = () => {
  if (pollTimer) return
  pollTimer = setInterval(() => {
    fetchReport({ silent: true })
  }, 5000)
}

const stopPolling = () => {
  if (!pollTimer) return
  clearInterval(pollTimer)
  pollTimer = null
}

const formatDate = (value) => {
  if (!value) return ''
  try {
    return new Date(value).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
  } catch {
    return value
  }
}

const applyReport = (report) => {
  if (!report) return
  reportData.value = report
  currentReportId.value = report.report_id || currentReportId.value
  error.value = ''
  emit('report-loaded', report)
  if (String(report.status || '').toLowerCase() === 'completed') {
    loading.value = false
    stopPolling()
  } else {
    loading.value = true
    startPolling()
  }
}

const fetchReport = async ({ silent = false } = {}) => {
  if (!props.simulationId) return

  if (!silent) {
    loading.value = Boolean(props.reportStarted || currentReportId.value)
    error.value = ''
  }

  try {
    if (props.reportId) {
      currentReportId.value = props.reportId
    }

    if (currentReportId.value) {
      const res = await getReport(currentReportId.value)
      if (res?.data) {
        applyReport(res.data)
        return
      }
    }

    const lookup = await getPaperReportBySimulation(props.simulationId)
    if (lookup?.data) {
      applyReport(lookup.data)
      return
    }

    if (!props.reportStarted) {
      loading.value = false
    }
  } catch (err) {
    const status = err?.response?.status
    if ((status === 404 || !status) && props.reportStarted) {
      loading.value = true
      startPolling()
      return
    }
    loading.value = false
    error.value = err.message || 'Could not load report data.'
    stopPolling()
  }
}

watch(
  () => [props.simulationId, props.reportId, props.reportStarted],
  () => {
    fetchReport()
  },
  { immediate: true }
)

onBeforeUnmount(() => {
  stopPolling()
})
</script>

<style scoped>
.report-workspace-panel {
  height: 100%;
  background: #ffffff;
}

.report-state {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 40px;
}

.report-state.loading .spinner {
  width: 32px;
  height: 32px;
  border: 3px solid #f3f4f6;
  border-top-color: #111827;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16px;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.state-copy h3 {
  font-size: 18px;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8px;
}

.state-copy p {
  font-size: 14px;
  color: #6b7280;
  max-width: 300px;
}

.report-document {
  height: 100%;
  overflow-y: auto;
  padding: 28px 30px 56px;
}

.report-header {
  padding-bottom: 20px;
  margin-bottom: 28px;
  border-bottom: 1px solid #e5e7eb;
}

.report-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  align-items: center;
  margin-bottom: 16px;
}

.report-tag {
  display: inline-flex;
  align-items: center;
  border: 1px solid #111827;
  border-radius: 999px;
  padding: 6px 10px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #111827;
}

.report-meta {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: #6b7280;
}

.view-paper-btn {
  margin-left: auto;
  background: #000;
  color: #fff;
  border: none;
  border-radius: 6px;
  padding: 6px 14px;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.view-paper-btn:hover {
  background: #333;
  transform: translateY(-1px);
}

.report-summary {
  font-size: 15px;
  line-height: 1.8;
  color: #4b5563;
  max-width: 780px;
}

.report-markdown {
  color: #111827;
}

.report-markdown :deep(h1),
.report-markdown :deep(h2),
.report-markdown :deep(h3) {
  color: #111827;
  font-weight: 600;
}

.report-markdown :deep(h2) {
  font-size: 20px;
  margin-top: 32px;
  margin-bottom: 16px;
  padding-bottom: 8px;
  border-bottom: 1px solid #f3f4f6;
}

.report-markdown :deep(p) {
  font-size: 15px;
  line-height: 1.7;
  margin-bottom: 16px;
}
</style>
