# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
# Set USE_ZEP=false to disable ALL Zep Cloud API calls (avoids 401 errors).
# When omitted, Zep is auto-enabled only if ZEP_API_KEY is set.
USE_ZEP=false
ZEP_API_KEY=your_zep_api_key_here

# ===== 图谱后端配置 =====
# 可选: zep | hivemind
GRAPH_PROVIDER=zep

# 当 GRAPH_PROVIDER=hivemind 时启用
HIVEMIND_API_URL=https://hivemind.davinciai.eu:8050
HIVEMIND_API_KEY=your_hivemind_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== Tavily Web Search（可选 — CSI Research Engine web exploration）=====
# Get a free API key at https://app.tavily.com/
# TAVILY_API_KEY=tvly-your_key_here
